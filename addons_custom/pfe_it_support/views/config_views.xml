<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Liste pour les Domaines IT -->
    <record id="view_pfe_it_domain_tree" model="ir.ui.view">
        <field name="name">pfe.it.domain.tree</field>
        <field name="model">pfe.it.domain</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Action pour les Domaines IT -->
    <record id="action_pfe_it_domain" model="ir.actions.act_window">
        <field name="name">Domaines IT</field>
        <field name="res_model">pfe.it.domain</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Vue Liste pour les Tags KB -->
    <record id="view_support_knowledge_tag_tree" model="ir.ui.view">
        <field name="name">support.knowledge.tag.tree</field>
        <field name="model">support.knowledge.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Action pour les Tags KB -->
    <record id="action_support_knowledge_tag" model="ir.actions.act_window">
        <field name="name">Tags Base de Connaissances</field>
        <field name="res_model">support.knowledge.tag</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Menus supplémentaires dans Configuration -->
    <menuitem id="menu_pfe_it_domain" 
              name="Domaines IT" 
              parent="menu_support_configuration" 
              action="action_pfe_it_domain" 
              sequence="20"/>

    <menuitem id="menu_support_knowledge_tag" 
              name="Tags KB" 
              parent="menu_support_configuration" 
              action="action_support_knowledge_tag" 
              sequence="30"/>
</odoo>
