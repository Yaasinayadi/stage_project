<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Inherit the standard res.users form view to expose:
            - x_support_role : read-only computed badge showing IT support role
            - it_domain_ids  : IT expertise domains (Many2many, visible only for Technicians)
        -->
        <record id="view_users_form_it_support" model="ir.ui.view">
            <field name="name">res.users.form.it_support</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <!-- Insert IT Support fields right after the native "role" field -->
                <xpath expr="//field[@name='role']" position="after">
                    <field name="x_support_role"
                           string="IT Support Role (computed)"
                           readonly="1"/>
                    <field name="it_domain_ids"
                           string="Domaines d'expertise IT"
                           widget="many2many_tags"
                           invisible="x_support_role != 'tech'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
