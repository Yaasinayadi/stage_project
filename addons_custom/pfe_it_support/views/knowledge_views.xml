<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Liste (List/Tree) -->
    <record id="view_support_knowledge_tree" model="ir.ui.view">
        <field name="name">support.knowledge.tree</field>
        <field name="model">support.knowledge</field>
        <field name="arch" type="xml">
            <list string="Base de Connaissances" decoration-info="is_published == True">
                <field name="name"/>
                <field name="category"/>
                <field name="author_id"/>
                <field name="is_published"/>
                <field name="write_date" string="Dernière modification"/>
            </list>
        </field>
    </record>

    <!-- Vue Formulaire -->
    <record id="view_support_knowledge_form" model="ir.ui.view">
        <field name="name">support.knowledge.form</field>
        <field name="model">support.knowledge</field>
        <field name="arch" type="xml">
            <form string="Article KB">
                <header>
                    <field name="is_published" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Ex: Configuration VPN..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="author_id"/>
                            <field name="ticket_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contenu / Solution" name="content">
                            <field name="solution" widget="html" options="{'style-inline': true}"/>
                        </page>
                        <page string="Aperçu" name="preview">
                            <group>
                                <field name="solution_preview" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue Recherche (Désactivée temporairement pour compatibilité Odoo 19) -->


    <!-- Action -->
    <record id="action_support_knowledge" model="ir.actions.act_window">
        <field name="name">Base de Connaissances</field>
        <field name="res_model">support.knowledge</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier article de connaissance !
            </p>
            <p>
                Documentez les solutions aux problèmes fréquents pour aider l'équipe technique.
            </p>
        </field>
    </record>

    <!-- Menu Item (Attaché au menu racine 'menu_support_root') -->
    <menuitem id="menu_support_knowledge"
              name="Base de Connaissances"
              parent="menu_root"
              action="action_support_knowledge"
              sequence="20"/>
</odoo>
