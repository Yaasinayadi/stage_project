<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Page du formulaire de création de ticket -->
    <template id="support_ticket_form_page" name="Support IT - Créer un ticket">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-primary text-white">
                                <h3 class="mb-0">🤖 Assistance IT - Ouvrir un ticket</h3>
                            </div>
                            <div class="card-body">
                                <form action="/support/submit" method="POST">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="mb-3">
                                        <label for="name" class="form-label fw-bold">Sujet du problème</label>
                                        <input type="text" class="form-control" id="name" name="name" required="1" placeholder="Ex: Mon mot de passe est expiré"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="description" class="form-label fw-bold">Description détaillée</label>
                                        <textarea class="form-control" id="description" name="description" rows="5" required="1" placeholder="Expliquez votre problème ici... L'IA se chargera de le catégoriser !"></textarea>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-primary w-100 btn-lg">Envoyer ma demande</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Page de confirmation (Merci) -->
    <template id="support_ticket_thanks" name="Merci - Support IT">
        <t t-call="website.layout">
            <div class="container text-center mt-5 mb-5">
                <div class="alert alert-success p-5 shadow-sm">
                    <h1 class="display-4">✅ Ticket Envoyé !</h1>
                    <p class="lead mt-3">Votre demande a été transmise à notre système. Notre IA est en cours d'analyse pour l'assigner au bon technicien.</p>
                    <a href="/" class="btn btn-outline-success mt-3">Retour à l'accueil</a>
                </div>
            </div>
        </t>
    </template>
</odoo>